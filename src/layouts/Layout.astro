---
import { getLangFromUrl, useTranslations, getLocalePath } from '../i18n/utils';

interface Props { title?: string }
const { title = 'Gabriel — Desarrollador Web' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const altLang = lang === 'es' ? 'en' : 'es';
const altPath = lang === 'es'
  ? `/en${Astro.url.pathname}`
  : Astro.url.pathname.replace('/en', '') || '/';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Gabriel — Desarrollador Web Frontend especializado en interfaces modernas." />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --black: #080808;
      --white: #f2f0eb;
      --g1: #141414;
      --g2: #202020;
      --g3: #333333;
      --g4: #555555;
      --g5: #888888;
      --g6: #bbbbbb;
      --D: 'Bebas Neue', sans-serif;
      --B: 'Outfit', sans-serif;
      --nav: 68px;
      --sp: 110px;
    }
    html { scroll-behavior: smooth; background: var(--black); color: var(--white); font-family: var(--B); }
    body { min-height: 100vh; overflow-x: hidden; }
    ::selection { background: var(--white); color: var(--black); }
    ::-webkit-scrollbar { width: 3px; }
    ::-webkit-scrollbar-track { background: var(--black); }
    ::-webkit-scrollbar-thumb { background: var(--g3); }
    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }
    button { cursor: pointer; font-family: var(--B); }
    .w { max-width: 1180px; margin: 0 auto; padding: 0 36px; }

    /* reveal */
    .r { opacity: 0; transform: translateY(22px); transition: opacity .65s cubic-bezier(.16,1,.3,1), transform .65s cubic-bezier(.16,1,.3,1); }
    .r.v { opacity: 1; transform: translateY(0); }
    .r.d1 { transition-delay: .1s; } .r.d2 { transition-delay: .2s; }
    .r.d3 { transition-delay: .3s; } .r.d4 { transition-delay: .4s; }

    /* section common */
    .sec { padding: var(--sp) 0; border-top: 1px solid var(--g2); }
    .slabel { font-size: .7rem; font-weight: 600; letter-spacing: .18em; text-transform: uppercase; color: var(--g4); margin-bottom: 44px; }
    .stitle { font-family: var(--D); font-size: clamp(3.5rem, 7vw, 6.5rem); line-height: .92; letter-spacing: .03em; color: var(--white); }

    /* buttons */
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 13px 30px; font-size: .8125rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; border-radius: 1px; border: 1px solid transparent; transition: background .2s, color .2s, border-color .2s, transform .18s; }
    .btn:hover { transform: translateY(-2px); }
    .bP { background: var(--white); color: var(--black); }
    .bP:hover { background: var(--g6); }
    .bG { border-color: var(--g3); color: var(--g6); }
    .bG:hover { border-color: var(--g6); color: var(--white); }

    @media (max-width: 640px) {
      .w { padding: 0 20px; }
    }
  </style>
</head>
<body>

<nav id="nb">
  <div class="w ni">
    <a href={getLocalePath(lang)} class="nl">G.</a>
    <div class="nls">
      <a href={`${getLocalePath(lang)}#inicio`}>{t.nav.inicio}</a>
      <a href={`${getLocalePath(lang)}#about`}>{t.nav.about}</a>
      <a href={`${getLocalePath(lang)}#proyectos`}>{t.nav.proyectos}</a>
      <a href={`${getLocalePath(lang)}#contacto`}>{t.nav.contacto}</a>
    </div>
    <a href={altPath} class="lb">{altLang.toUpperCase()}</a>
  </div>
</nav>

<main><slot /></main>

<footer>
  <div class="w fi2">
    <span class="flogo">G.</span>
    <span class="fcopy">&copy; {new Date().getFullYear()} Gabriel — {t.footer}</span>
  </div>
</footer>

<style>
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 200; height: var(--nav); transition: background .4s, border-color .4s; border-bottom: 1px solid transparent; }
  nav.sc { background: rgba(8,8,8,.9); backdrop-filter: blur(16px); border-color: var(--g2); }
  .ni { display: flex; align-items: center; justify-content: space-between; height: 100%; }
  .nl { font-family: var(--D); font-size: 2rem; letter-spacing: .04em; }
  .nls { display: flex; gap: 36px; }
  .nls a { font-size: .8rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: var(--g5); transition: color .2s; position: relative; }
  .nls a::after { content: ''; position: absolute; bottom: -3px; left: 0; width: 0; height: 1px; background: var(--white); transition: width .25s; }
  .nls a:hover { color: var(--white); }
  .nls a:hover::after { width: 100%; }
  .lb { font-size: .75rem; font-weight: 600; letter-spacing: .12em; color: var(--g5); border: 1px solid var(--g3); padding: 5px 13px; border-radius: 1px; transition: color .2s, border-color .2s; }
  .lb:hover { color: var(--white); border-color: var(--white); }
  footer { border-top: 1px solid var(--g2); padding: 28px 0; }
  .fi2 { display: flex; align-items: center; justify-content: space-between; }
  .flogo { font-family: var(--D); font-size: 1.6rem; letter-spacing: .04em; }
  .fcopy { font-size: .75rem; font-weight: 400; color: var(--g4); }
  @media (max-width: 640px) {
    .nls { display: none; }
    .fi2 { flex-direction: column; gap: 10px; text-align: center; }
  }
</style>

<script>
  window.addEventListener('scroll', () => {
    document.getElementById('nb')?.classList.toggle('sc', scrollY > 20);
  });
  const ro = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('v'); });
  }, { threshold: .08 });
  document.querySelectorAll('.r').forEach(el => ro.observe(el));
</script>
</body>
</html>
